APP_ENV=dev
CONFIG_DIR=config

APP__DATABASE__URL=db_url

APP__AUTH__JWT_SECRET=change-me-jwt-secret-at-least-32-chars
APP__AUTH__OTP_SECRET=change-me-otp-secret-at-least-32-chars

APP__STORAGE__ENDPOINT=https://account-id.r2.cloudflarestorage.com
APP__STORAGE__ACCESS_KEY_ID=change-me-r2-access-key-id
APP__STORAGE__SECRET_ACCESS_KEY=change-me-r2-secret-access-key

RUST_LOG=debug
